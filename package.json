{
  "name": "api-service",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@8.15.1",
  "description": "A website for public api service, build with nuxt",
  "author": "Kuizuo <hi@kuizuo.cn> (https://kuizuo.cn)",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/kuizuo/api-service",
    "type": "git"
  },
  "keywords": [
    "nuxt",
    "api",
    "service"
  ],
  "scripts": {
    "build": "nuxi build",
    "build:cloudflare": "NITRO_PRESET=cloudflare_module nuxi build",
    "deploy:cloudflare": "pnpm run build:cloudflare && wrangler deploy",
    "dev": "nuxi dev",
    "start": "node .output/server/index.mjs",
    "start:pm2": "pm2 start ecosystem.config.js",
    "preview": "nuxi preview",
    "preview:cloudflare": "pnpm run build:cloudflare && wrangler dev",
    "cf-typegen": "wrangler types",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.6.3",
    "@iconify-json/carbon": "^1.1.28",
    "@iconify-json/mdi": "^1.1.64",
    "@nuxt/content": "^2.13.4",
    "@nuxt/ui": "^2.22.3",
    "@nuxtjs/color-mode": "^3.5.2",
    "@pinia/nuxt": "^0.11.3",
    "@types/lodash": "^4.14.202",
    "@types/qrcode": "^1.5.5",
    "@vueuse/nuxt": "^10.11.1",
    "dayjs": "^1.11.10",
    "eslint": "^8.56.0",
    "highlight.js": "^11.9.0",
    "nuxt": "^3.21.8",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.3",
    "rate-limiter-flexible": "^3.0.6",
    "typescript": "^5.3.3",
    "wrangler": "4.103.0"
  }
}
